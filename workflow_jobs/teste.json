{
  "name": "JOB_PCRM_INGESTION",
  "email_notifications": {
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {
    "on_failure": [
      {
        "id": "lknsklfnkv"
      }
    ],
    "on_duration_warning_threshold_exceeded": [
      {
        "id": "lknsklfnkv"
      }
    ]
  },
  "timeout_seconds": 43200,
  "health": {
    "rules": [
      {
        "metric": "RUN_DURATION_SECONDS",
        "operator": "GREATER_THAN",
        "value": 10800
      }
    ]
  },
  "schedule": {
    "quartz_cron_expression": "0 * * * * ?",
    "timezone_id": "America/Sao_Paulo",
    "pause_status": "PAUSED"
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "ename_task",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "path",
        "source": "WORKSPACE"
      },
      "libraries": [
        {
          "pypi": {
            "package": "kafka-python"
          }
        },
        {
          "pypi": {
            "package": "pymongo"
          }
        }
      ],
      "job_cluster_key": "Job_cluster",
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {}
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "Job_cluster",
      "new_cluster": {
        "cluster_name": "",
        "spark_version": "15.4.x-scala2.12",
        "azure_attributes": {},
        "custom_tags": {
          "dbw.cls.centro_de_custo": "crm",
          "dbw.cls.criticalidade": "5",
          "dbw.dominio": "platfun",
          "dbw.departamento": "123454",
          "dbw.cls.app": "crm_orquestrador"
        },
        "instance_pool_id": "Standart_E8s_v5.MEMORY_OPTIMIZED.SPOT_WITH_FALLBACK",
        "policy_id": "Prep M",
        "driver_instance_pool_id": "Standart_E8s_v5.MEMORY_OPTIMIZED.ON_DEMAND",
        "data_security_mode": "USER_ISOLATION",
        "runtime_engine": "STANDARD",
        "num_workers": 1
      }
    }
  ],
  "tags": {
    "dbw.wkf.app": "crm_orquestrador",
    "dbw.wkf.centro_de_custo": "crm",
    "dbw.wkf.criticalidade": "5",
    "dbw.wkf.departamento": "123454",
    "dbw.wkf.dominio": "platfun"
  },
  "parameters": [],
  "run_as": {
    "service_principal_name": "id"
  }
}